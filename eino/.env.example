# ============================================================
# Eino 生产级配置示例（复制为 .env 后按需修改）
# ============================================================

# ---------- 鉴权（必填，缺失则服务拒绝启动） ----------
# JWT 签名密钥：请使用足够随机的长字符串（例如 `openssl rand -hex 32`）。
JWT_SECRET=change-me-to-a-long-random-secret

# 初始管理员（仅当数据库为空时生效，用于首次登录）。
# 生产务必修改默认密码！
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin

# 会话令牌有效期（秒，默认 86400 = 24h，由代码默认值控制，此处可覆盖）
# JWT_TTL_SEC=86400

# ---------- 速率限制（默认 20 RPS / 40 突发） ----------
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# ---------- 流式响应超时（秒，默认 240） ----------
STREAM_TIMEOUT_SEC=240

# ---------- SQLite 数据库路径（默认 data/eino.db） ----------
SQLITE_PATH=data/eino.db

# ============================================================
# 以下为原有业务配置（保留以便参考）
# ============================================================
# ARK_API_KEY=
# ARK_ENDPOINT=
# DEEPSEEK_API_KEY=
# EMBEDDING_EP=
# RAG_DATA_DIR=
# CORS_ALLOW_ORIGINS=*
